        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "~21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "~21.1.2",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@date-fns/tz": "^1.4.1",
    "@worktile/gantt": "^21.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
